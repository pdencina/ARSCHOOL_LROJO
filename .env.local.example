# ============================================================
# AR School — Variables de Entorno
# ============================================================
# Copia este archivo como .env.local y completa con tus valores.
# Obtener credenciales de: https://supabase.com/dashboard/project/_/settings/api
# ============================================================

# URL pública del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima (anon key) — segura para el cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (service_role) — SOLO servidor, nunca exponer al cliente
# Se usa para operaciones admin que bypasean RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base de la aplicación
# Local: http://localhost:3000
# Producción: https://tu-dominio.vercel.app (o dominio custom)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
